PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5000
MONGODB_URI=mongodb://127.0.0.1:27017/vendorflow
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d
JWT_OTP_SECRET=replace_with_long_random_otp_secret
JWT_OTP_EXPIRES_IN=10m
GOOGLE_CLIENT_ID=your_google_client_id
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@vendorflow.local
UPLOAD_DIR=uploads
